---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import standardsData from '../data/standards.json';

interface StandardItem {
  category: string;
  framework: string;
  subject: string;
  keywords: string;
  detail: string;
}

const data = standardsData as StandardItem[];

const categories = [...new Set(data.map(d => d.category))];

const categoryItems: Record<string, StandardItem[]> = {};
for (const cat of categories) {
  categoryItems[cat] = data.filter(d => d.category === cat);
}

const categoryFrameworks: Record<string, string[]> = {};
for (const cat of categories) {
  const items = categoryItems[cat];
  categoryFrameworks[cat] = [...new Set(items.map(d => d.framework))];
}

const categoryEmoji: Record<string, string> = {
  '\u79d1\u6280': '\ud83d\udd2c',
  '\u8fdd\u6cd5': '\u2696\ufe0f',
  '\u5b97\u6559': '\ud83d\udd4a\ufe0f'
};

const categoriesJson = JSON.stringify(categories);
const categoryFrameworksJson = JSON.stringify(categoryFrameworks);

const fullDataMap: Record<string, {category: string, framework: string, subject: string, keywords: string, detail: string}[]> = {};
for (const cat of categories) {
  fullDataMap[cat] = categoryItems[cat].map(item => ({
    category: item.category,
    framework: item.framework,
    subject: item.subject,
    keywords: item.keywords,
    detail: item.detail
  }));
}
const fullDataJson = JSON.stringify(fullDataMap);
---

<Layout title="\u5185\u5bb9\u7814\u5224\u6807\u51c6 - \u5185\u5bb9\u98ce\u63a7\u65e5\u5386">
  <Header />

  <div id="standards-data" hidden
    data-categories={categoriesJson}
    data-frameworks={categoryFrameworksJson}
    data-full={fullDataJson}
  ></div>

  <div class="max-w-6xl mx-auto px-4 py-6 flex gap-6">

    <!-- Sidebar: Category Only -->
    <aside class="w-36 shrink-0">
      <div class="sticky top-20">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3 px-2">\u5206\u7c7b</p>
        <nav class="space-y-1" id="category-nav">
          {categories.map((cat, i) => (
            <button
              class:list={[
                "category-btn w-full text-left px-3 py-2.5 rounded-lg text-sm transition-all flex items-center justify-between",
                i === 0 ? "bg-blue-50 text-blue-700 font-semibold" : "text-gray-700 hover:bg-gray-100"
              ]}
              data-category={cat}
              onclick={'switchCategory("' + cat + '")'}
            >
              <span>{categoryEmoji[cat] || '\ud83d\udccb'} {cat}</span>
              <span class:list={[
                "text-xs rounded-full px-1.5 py-0.5 font-medium",
                i === 0 ? "bg-blue-100 text-blue-600" : "bg-gray-100 text-gray-500"
              ]}>{categoryItems[cat].length}</span>
            </button>
          ))}
        </nav>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 min-w-0">

      <div class="mb-5 flex items-center justify-between">
        <div>
          <h1 class="text-xl font-bold text-gray-900">\ud83d\udccb \u5185\u5bb9\u7814\u5224\u6807\u51c6</h1>
          <p class="text-sm text-gray-400 mt-0.5" id="page-subtitle"></p>
        </div>
        <div class="flex gap-1 bg-gray-100 rounded-lg p-1">
          {categories.map((cat, i) => (
            <button
              class:list={[
                "cat-filter-btn px-3 py-1.5 text-xs font-medium rounded-md",
                i === 0 ? "bg-white text-gray-700 shadow-sm" : "text-gray-500 hover:text-gray-700"
              ]}
              data-cat={cat}
              onclick={'switchCategory("' + cat + '")'}
            >
              {categoryEmoji[cat]} {cat}
            </button>
          ))}
        </div>
      </div>

      <!-- Standards Container -->
      <div id="standards-container" class="space-y-4">
      </div>

      <div id="empty-state" class="hidden text-center py-20 text-gray-300">
        <div class="text-5xl mb-3">\ud83d\udced</div>
        <p class="text-sm">\u6682\u65e0\u6807\u51c6\u6570\u636e</p>
      </div>

    </main>
  </div>

  <script is:inline>
    var el = document.getElementById('standards-data');
    var categories = JSON.parse(el.dataset.categories);
    var frameworks = JSON.parse(el.dataset.frameworks);
    var fullData = JSON.parse(el.dataset.full);

    var categoryEmoji = {'\u79d1\u6280': '\ud83d\udd2c', '\u8fdd\u6cd5': '\u2696\ufe0f', '\u5b97\u6559': '\ud83d\udd4a\ufe0f'};

    var activeCategory = categories[0];

    function renderStandards() {
      var container = document.getElementById('standards-container');
      var items = fullData[activeCategory] || [];
      var subtitle = document.getElementById('page-subtitle');

      if (!items || items.length === 0) {
        container.innerHTML = '';
        document.getElementById('empty-state').classList.remove('hidden');
        subtitle.textContent = '';
        return;
      }

      document.getElementById('empty-state').classList.add('hidden');
      subtitle.textContent = activeCategory + ' \u2014 \u5171 ' + items.length + ' \u6761';

      // Group items by framework
      var groups = {};
      var fwOrder = [];
      for (var i = 0; i < items.length; i++) {
        var fw = items[i].framework;
        if (!groups[fw]) {
          groups[fw] = [];
          fwOrder.push(fw);
        }
        groups[fw].push(items[i]);
      }

      var html = '';
      var num = 0;

      for (var g = 0; g < fwOrder.length; g++) {
        var fw = fwOrder[g];
        var groupItems = groups[fw];

        // Framework section header
        html += '<div class="mb-4">';
        html += '<div class="flex items-center gap-2 mb-3">';
        html += '<span class="inline-flex items-center px-2.5 py-0.5 rounded-md bg-slate-100 text-xs font-semibold text-slate-700">' + escapeHtml(fw) + '</span>';
        html += '<span class="text-xs text-gray-400">' + groupItems.length + '\u6761</span>';
        html += '<div class="flex-1 h-px bg-gray-100"></div>';
        html += '</div>';

        // Cards in this framework group
        html += '<div class="space-y-3">';
        for (var j = 0; j < groupItems.length; j++) {
          num++;
          var item = groupItems[j];
          var hasDetail = item.detail && item.detail.trim().length > 0;

          html += '<article class="bg-white border border-gray-200 rounded-xl p-4 shadow-sm hover:shadow-md transition-shadow">';

          // Subject header
          html += '<div class="flex items-start gap-3">';
          html += '<span class="shrink-0 w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-xs font-bold">' + num + '</span>';
          html += '<div class="flex-1 min-w-0">';
          html += '<h3 class="text-sm font-semibold text-gray-900">' + escapeHtml(item.subject) + '</h3>';
          html += '</div>';
          html += '</div>';

          // Keywords section
          if (item.keywords && item.keywords.trim()) {
            html += '<div class="bg-amber-50 border border-amber-200 rounded-lg p-3 mt-3 ml-9">';
            html += '<div class="text-xs font-semibold text-amber-700 mb-1.5 flex items-center gap-1"><span>\ud83d\udd0d</span> \u91cd\u70b9\u63d0\u9192 / \u8bc6\u522b\u4fe1\u606f</div>';
            html += '<p class="text-xs text-amber-900 leading-relaxed whitespace-pre-wrap">' + escapeHtml(item.keywords) + '</p>';
            html += '</div>';
          }

          // Detail section (collapsible)
          if (hasDetail) {
            html += '<details class="ml-9 mt-2 group">';
            html += '<summary class="text-xs text-gray-400 cursor-pointer select-none hover:text-gray-600 list-none flex items-center gap-1">';
            html += '<span class="inline-block transition-transform group-open:rotate-90">\u25b6</span> \u6807\u51c6\u8be6\u60c5';
            html += '</summary>';
            html += '<div class="mt-2 pl-3 border-l-2 border-indigo-200 text-xs text-gray-600 leading-relaxed whitespace-pre-wrap">' + escapeHtml(item.detail) + '</div>';
            html += '</details>';
          }

          html += '</article>';
        }
        html += '</div>';
        html += '</div>';
      }

      container.innerHTML = html;
    }

    function escapeHtml(str) {
      if (!str) return '';
      return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function switchCategory(cat) {
      activeCategory = cat;

      // Update sidebar category buttons
      document.querySelectorAll('.category-btn').forEach(function(btn) {
        var bc = btn.dataset.category;
        var badge = btn.querySelector('span:last-child');
        btn.classList.remove('bg-blue-50', 'text-blue-700', 'font-semibold');
        if (bc === cat) {
          btn.classList.add('bg-blue-50', 'text-blue-700', 'font-semibold');
          if (badge) { badge.classList.remove('bg-gray-100', 'text-gray-500'); badge.classList.add('bg-blue-100', 'text-blue-600'); }
        } else {
          btn.classList.add('text-gray-700');
          if (badge) { badge.classList.remove('bg-blue-100', 'text-blue-600'); badge.classList.add('bg-gray-100', 'text-gray-500'); }
        }
      });

      // Update top filter buttons
      document.querySelectorAll('.cat-filter-btn').forEach(function(btn) {
        btn.classList.remove('bg-white', 'text-gray-700', 'shadow-sm');
        btn.classList.add('text-gray-500');
        if (btn.dataset.cat === cat) {
          btn.classList.add('bg-white', 'text-gray-700', 'shadow-sm');
          btn.classList.remove('text-gray-500');
        }
      });

      renderStandards();
    }

    // Initialize
    renderStandards();
    window.switchCategory = switchCategory;
  </script>
</Layout>
